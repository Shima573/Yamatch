<header id="header" class="scrolled">
  <%= link_to root_path, class: "logo" do %>
    やま<em>ッチ</em>
  <% end %>

  <div class="nav-links">
    <% if user_signed_in? %>
      <%= link_to edit_user_registration_path, class: "user-icon-link" do %>
        <div class="user-icon">アイコン画像</div>
      <% end %>

      <%= link_to "ログアウト",
                  destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "logout-link" %>

    <% else %>
      <a href="#" class="nav-link">使い方</a>
      <a href="#" class="nav-link">機能</a>

      <%= link_to "ログイン", new_user_session_path, class: "nav-link" %>
      <%= link_to "相性診断をする", "#", class: "nav-cta" %>
    <% end %>
  </div>
</header>
