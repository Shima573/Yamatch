<div class="grid grid-cols-1 gap-7">
    <div>
        <div class="flex justify-between items-end mb-2">
            <span class="text-slate-600 font-bold">体力レベル</span>
            <span class="text-2xl font-black text-primary-50"><%= diagnosis.recommended_physical_max %><span
                    class="text-sm text-primary-90 ml-1">/ 10</span></span>
        </div>
        <div class="w-full bg-primary-90/10 rounded-full h-4 overflow-hidden">
            <div class="bg-primary-50 h-full rounded-full transition-all duration-1000"
                style="width: <%= diagnosis.recommended_physical_max * 10 %>%"></div>
        </div>
        <p class="mt-3 text-xs text-primary-900">※あなたの安全圏: <%= diagnosis.recommended_physical_min %> ~ <%= diagnosis.recommended_physical_max %></p>
    </div>
    <div>
        <div class="flex justify-between items-end mb-2">
            <span class="text-slate-600 font-bold">技術ランク</span>
            <span class="text-2xl font-black text-primary-800">
                <%= case diagnosis.recommended_technical_max
                  when 1 then 'A' when 2 then 'B' when 3 then 'C' when 4 then 'D' when 5 then 'E'
                  end %>
                <span class="text-sm text-primary-90 ml-1">相当</span>
            </span>
        </div>
        <div class="flex gap-1 h-4">
            <% (1..5).each do |i| %>
            <div
                class="flex-1 rounded-sm <%= i <= diagnosis.recommended_technical_max ? 'bg-primary-800' : 'bg-primary-90/10' %>">
            </div>
            <% end %>
        </div>
        <p class="mt-3 text-xs text-primary-900">※A: 初級 〜 E: 超上級（岩場・鎖場の経験に基づく判定）</p>
    </div>
</div>
