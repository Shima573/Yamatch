        <span class="text-[10px] font-bold">記録</span>
      <% end %>

      <!-- 山一覧 -->
      <%= link_to mountains_path, class: "flex-1 flex flex-col items-center py-3 border-b-2 border-transparent text-gray-400" do %>
        <span class="text-2xl mb-1">🏔️</span>
        <span class="text-[10px] font-bold">山一覧</span>
      <% end %>

      <!-- 設定 -->
      <%= link_to "#", class: "flex-1 flex flex-col items-center py-3 border-b-2 border-transparent text-gray-400" do %>
        <span class="text-2xl mb-1">⚙️</span>
        <span class="text-[10px] font-bold">設定</span>
      <% end %>
    </div>
  </nav>
